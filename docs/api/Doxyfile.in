# LogScope Doxygen configuration (generated by CMake).

PROJECT_NAME           = "LogScope"
PROJECT_NUMBER         = @PROJECT_VERSION@
PROJECT_BRIEF          = "Generic, extensible log analysis platform"
OUTPUT_DIRECTORY       = @DOXYGEN_OUTPUT_DIR@
CREATE_SUBDIRS         = NO

OPTIMIZE_OUTPUT_FOR_C  = NO
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES
BUILTIN_STL_SUPPORT    = YES
CPP_CLI_SUPPORT        = NO

INPUT                  = @DOXYGEN_SOURCE_DIR@/core \
                         @DOXYGEN_SOURCE_DIR@/apps \
                         @DOXYGEN_MAINPAGE@
INPUT_ENCODING         = UTF-8
FILE_PATTERNS          = *.hpp *.h *.inl
RECURSIVE              = YES
EXCLUDE_PATTERNS       = */tests/* \
                         */fuzz/* \
                         *_test.cpp \
                         *test.hpp \
                         *malformed*
USE_MDFILE_AS_MAINPAGE = @DOXYGEN_MAINPAGE@

EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
EXTRACT_LOCAL_CLASSES  = NO
HIDE_UNDOC_MEMBERS     = YES
HIDE_UNDOC_CLASSES     = YES
HIDE_FRIEND_COMPOUNDS  = YES
HIDE_IN_BODY_DOCS      = NO
INTERNAL_DOCS          = NO
BRIEF_MEMBER_DESC      = YES
REPEAT_BRIEF           = YES
JAVADOC_AUTOBRIEF      = NO
INHERIT_DOCS           = YES
SEPARATE_MEMBER_PAGES  = NO
TAB_SIZE               = 4

WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO
WARN_FORMAT            = "$file:$line: $text"
WARN_LOGFILE           =

SOURCE_BROWSER         = NO
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = YES
REFERENCED_BY_RELATION = NO
REFERENCES_RELATION    = NO

ALPHABETICAL_INDEX     = YES
GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_TREEVIEW      = YES
GENERATE_LATEX         = NO
GENERATE_XML           = NO

DISABLE_INDEX          = NO
GENERATE_TAGFILE       =
ENUM_VALUES_PER_LINE   = 1

SEARCHENGINE           = YES
SERVER_BASED_SEARCH    = NO

MACRO_EXPANSION        = NO
EXPAND_ONLY_PREDEF     = NO
PREDEFINED             =
EXPAND_AS_DEFINED      =
SKIP_FUNCTION_MACROS   = YES
