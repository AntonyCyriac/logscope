{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug LogScope",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/logscope.exe",
            "args": [
                "${workspaceFolder}/samples/sample.log"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "C:/msys64/ucrt64/bin/gdb.exe",
            "preLaunchTask": "Build LogScope"
        }
    ]
}