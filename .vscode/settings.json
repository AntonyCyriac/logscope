{
    "editor.formatOnSave": true,

    "[cpp]": {
        "editor.defaultFormatter": "xaver.clang-format"
    },

    "[c]": {
        "editor.defaultFormatter": "xaver.clang-format"
    },

    "clang-format.executable": "C:/msys64/ucrt64/bin/clang-format.exe",

    "C_Cpp.clang_format_style": "file",

    "files.associations": {
        "*.tpp": "cpp",
        "*.ipp": "cpp"
    }
}